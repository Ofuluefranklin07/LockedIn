# Copy this file to .env.local and replace the placeholder values.
# Never commit your real Gemini API key.

# GEMINI_API_KEY: Required for Gemini AI API calls in local development.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# VITE_GEMINI_API_KEY: Use this same value for Vite/Vercel live builds.
# Frontend env values are public in the browser bundle.
VITE_GEMINI_API_KEY="MY_VITE_GEMINI_API_KEY"

# Optional: override the default model. The app falls back automatically if this is rejected.
VITE_GEMINI_MODEL="gemini-2.5-flash"

# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
VITE_APP_URL="MY_APP_URL"
